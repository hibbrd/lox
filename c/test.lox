fun fib(n) {
    if (n < 2) return n;
	return fib(n - 2) + fib(n - 1);
}

var start = clock();
print fib(10);
print clock() - start;

class CoffeeMaker {
	init(coffee) {
		this.coffee = coffee;
	}

	brew() {
		print "Enjoy your cup of " + this.coffee;
		this.coffee = nil;
	}
}

var maker = CoffeeMaker("coffee and chicory");
maker.brew();
